# 生产环境示例 — 复制后填入真实值，切勿提交含密钥的文件

APP_ENV=production
BACKEND_PORT=8080

# 可使用完整 DSN，或分别配置 DB_* 变量（二选一，DSN 优先）
DATABASE_DSN=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=yijing
DB_PASSWORD=
DB_NAME=yijing

AI_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_OUTPUT_TOKENS=1800

# 生产环境必须关闭 debug 路由
ENABLE_DEBUG_ROUTES=false
CORS_ALLOWED_ORIGINS=https://your-domain.com
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=20

# migration 工具 SQL 目录（容器内通常为 /sql）
SQL_DIR=/sql
