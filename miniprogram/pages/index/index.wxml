<view class="page page--home">
  <view class="home-hero">
    <text class="home-hero__eyebrow">{{brand.eyebrow}}</text>
    <text class="home-hero__title">{{brand.title}}</text>
    <text class="home-hero__subtitle">{{brand.subtitle}}</text>
    <text class="home-hero__note">{{brand.note}}</text>
    <view class="home-hero__actions">
      <navigator class="home-hero__button home-hero__button--primary" url="/pages/ask/ask">开始问事</navigator>
      <navigator class="home-hero__button home-hero__button--secondary" url="/pages/history/history">查看历史</navigator>
    </view>
  </view>

  <view class="home-section home-section--modules">
    <view class="home-section__header">
      <text class="home-section__title">三大主模块</text>
      <text class="home-section__desc">按问题类型选择工具，入口保持清晰独立。</text>
    </view>
    <view class="home-modules">
      <home-module-card
        wx:for="{{modules}}"
        wx:key="key"
        title="{{item.title}}"
        subtitle="{{item.subtitle}}"
        tags="{{item.tags}}"
        button-text="{{item.buttonText}}"
        url="{{item.url}}"
        accent="{{item.accent}}"
      ></home-module-card>
    </view>
  </view>

  <view class="home-section home-section--scenes">
    <view class="home-section__header">
      <text class="home-section__title">常见场景</text>
      <text class="home-section__desc">场景入口会回到对应主模块，不新增独立业务流程。</text>
    </view>
    <navigator
      wx:for="{{sceneItems}}"
      wx:key="key"
      class="home-scene-card"
      url="{{item.url}}"
    >
      <view class="home-scene-card__main">
        <text class="home-scene-card__title">{{item.title}}</text>
        <text class="home-scene-card__subtitle">{{item.subtitle}}</text>
      </view>
      <text class="home-scene-card__button">{{item.buttonText}}</text>
    </navigator>
    <view class="home-planned-scenes">
      <view class="home-planned-chip" wx:for="{{plannedScenes}}" wx:key="key">
        <text class="home-planned-chip__title">{{item.title}}</text>
        <text class="home-planned-chip__status">规划中</text>
      </view>
    </view>
  </view>

  <view class="home-section home-section--tools">
    <view class="home-section__header">
      <text class="home-section__title">传统文化小工具</text>
      <text class="home-section__desc">更多传统文化小工具正在规划中。</text>
    </view>
    <view class="home-tool-grid">
      <view class="home-tool-card" wx:for="{{toolItems}}" wx:key="key">
        <text class="home-tool-card__title">{{item.title}}</text>
        <text class="home-tool-card__status">规划中</text>
      </view>
    </view>
  </view>

  <view class="home-boundary">
    <text class="home-boundary__title">使用边界说明</text>
    <view class="home-boundary__list">
      <text class="home-boundary__item" wx:for="{{boundaryItems}}" wx:key="*this">· {{item}}</text>
    </view>
  </view>

  <view class="home-secondary">
    <navigator class="home-secondary__link" url="/pages/history/history">
      <text>历史记录</text>
      <text class="home-secondary__arrow">→</text>
    </navigator>
    <navigator class="home-secondary__link" url="/pages/about/about">
      <text>关于与说明</text>
      <text class="home-secondary__arrow">→</text>
    </navigator>
  </view>

  <text wx:if="{{sessionStatus === 'retry_later'}}" class="session-hint">匿名会话暂未连接，进入功能页时将自动重试。</text>
  <text class="home-compliance">{{complianceNote}}</text>
</view>
