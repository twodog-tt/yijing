.page--home {
  min-height: 100vh;
  padding: 24rpx 28rpx 44rpx;
  background:
    linear-gradient(180deg, rgba(185, 146, 85, 0.1) 0%, rgba(185, 146, 85, 0) 280rpx),
    #17130f;
  color: #f4ead8;
}

.home-hero {
  position: relative;
  overflow: hidden;
  margin-bottom: 26rpx;
  padding: 30rpx 28rpx 28rpx;
  border: 1rpx solid rgba(185, 146, 85, 0.32);
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(185, 146, 85, 0.16) 0%, rgba(185, 146, 85, 0) 42%),
    #211a14;
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.22);
}

.home-hero__eyebrow {
  display: block;
  color: #d6b06d;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.home-hero__title {
  display: block;
  margin-top: 10rpx;
  color: #fff7e6;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.45;
}

.home-hero__subtitle {
  display: block;
  margin-top: 8rpx;
  color: #e8d8bd;
  font-size: 25rpx;
  line-height: 1.55;
}

.home-hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.home-hero__button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 198rpx;
  min-height: 72rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.home-hero__button--primary {
  background: #d6b06d;
  color: #211a14;
}

.home-hero__button--secondary {
  border: 1rpx solid rgba(214, 176, 109, 0.45);
  color: #f4ead8;
}

.home-section {
  margin-bottom: 28rpx;
}

.home-section__header {
  margin-bottom: 14rpx;
}

.home-section__title {
  display: block;
  color: #fff7e6;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.45;
}

.home-section__desc {
  display: block;
  margin-top: 4rpx;
  color: #bcae98;
  font-size: 22rpx;
  line-height: 1.55;
}

.home-modules {
  margin-bottom: -14rpx;
}

.home-scene-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 108rpx;
  padding: 20rpx 22rpx 20rpx 24rpx;
  border: 1rpx solid rgba(185, 146, 85, 0.22);
  border-radius: 16rpx;
  background: rgba(255, 250, 240, 0.94);
  box-sizing: border-box;
}

.home-scene-card__main {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
}

.home-scene-card__title {
  color: #292524;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.4;
}

.home-scene-card__subtitle {
  color: #57534e;
  font-size: 22rpx;
  line-height: 1.55;
}

.home-scene-card__button {
  flex: 0 0 auto;
  min-width: 82rpx;
  color: #7c4a16;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.45;
  text-align: right;
}

.home-planned-scenes {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.home-planned-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 14rpx;
  border: 1rpx solid rgba(214, 176, 109, 0.14);
  border-radius: 999rpx;
  background: rgba(255, 247, 230, 0.045);
}

.home-planned-chip__title {
  color: #bcae98;
  font-size: 22rpx;
  line-height: 1.4;
}

.home-planned-chip__status {
  color: #8f816b;
  font-size: 19rpx;
  line-height: 1.4;
}

.home-tool-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: -14rpx;
}

.home-tool-card {
  flex: 0 0 48.5%;
  min-height: 110rpx;
  margin-bottom: 14rpx;
  padding: 18rpx 16rpx;
  border: 1rpx solid rgba(214, 176, 109, 0.14);
  border-radius: 16rpx;
  background: rgba(255, 247, 230, 0.05);
  box-sizing: border-box;
}

.home-tool-card__title {
  display: block;
  color: #e8d8bd;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.45;
}

.home-tool-card__hint {
  display: block;
  margin-top: 4rpx;
  color: #a69274;
  font-size: 20rpx;
  line-height: 1.35;
}

.home-tool-card__status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
  padding: 4rpx 10rpx;
  border: 1rpx solid rgba(214, 176, 109, 0.16);
  border-radius: 999rpx;
  background: rgba(255, 247, 230, 0.045);
  color: #8f816b;
  font-size: 19rpx;
  line-height: 1.4;
}

.home-boundary {
  margin-bottom: 18rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(214, 176, 109, 0.14);
  border-radius: 18rpx;
  background: rgba(255, 247, 230, 0.045);
}

.home-boundary__title {
  display: block;
  margin-bottom: 10rpx;
  color: #e8d8bd;
  font-size: 24rpx;
  font-weight: 700;
}

.home-boundary__list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.home-boundary__item {
  color: #bcae98;
  font-size: 22rpx;
  line-height: 1.55;
}

.home-secondary {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.home-secondary__link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 82rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(214, 176, 109, 0.14);
  border-radius: 16rpx;
  background: rgba(255, 247, 230, 0.05);
  color: #f4ead8;
  font-size: 27rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.home-secondary__arrow {
  color: #d6b06d;
}

.home-compliance {
  display: block;
  padding: 20rpx;
  border-radius: 14rpx;
  background: rgba(0, 0, 0, 0.16);
  color: #a69274;
  font-size: 22rpx;
  line-height: 1.75;
}

.session-hint {
  display: block;
  margin-bottom: 16rpx;
  color: #d6b06d;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: center;
}
