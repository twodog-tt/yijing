.page--home {
  padding-bottom: 48rpx;
}

.home-hero {
  position: relative;
  overflow: hidden;
  margin-bottom: 30rpx;
  padding: 40rpx 30rpx 34rpx;
  border: 1rpx solid rgba(252, 211, 77, 0.24);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #1c1917 0%, #292524 100%);
  box-shadow: 0 16rpx 36rpx rgba(28, 25, 23, 0.18);
}

.home-hero__aura {
  position: absolute;
  top: -40rpx;
  right: -20rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(252, 211, 77, 0.16) 0%, rgba(252, 211, 77, 0) 70%);
  pointer-events: none;
}

.home-hero__eyebrow {
  display: block;
  color: #fcd34d;
  font-size: 24rpx;
  letter-spacing: 4rpx;
}

.home-hero__title {
  display: block;
  margin-top: 16rpx;
  color: #fef3c7;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.45;
}

.home-hero__subtitle {
  display: block;
  margin-top: 14rpx;
  color: #d6d3d1;
  font-size: 24rpx;
  line-height: 1.7;
}

.home-modules {
  margin-bottom: 12rpx;
}

.home-scenes {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 20rpx;
  background: #fafaf9;
}

.home-scenes__title {
  display: block;
  margin-bottom: 16rpx;
  color: #57534e;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.home-scene-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.home-scene-card__main {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.home-scene-card__title {
  color: #292524;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.4;
}

.home-scene-card__subtitle,
.home-scene-card__description {
  color: #57534e;
  font-size: 23rpx;
  line-height: 1.55;
}

.home-scene-card__button {
  flex: 0 0 auto;
  max-width: 168rpx;
  color: #92400e;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.45;
  text-align: right;
}

.home-boundary {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #fde68a;
  border-radius: 24rpx;
  background: #fffbeb;
}

.home-boundary__title {
  display: block;
  margin-bottom: 16rpx;
  color: #78350f;
  font-size: 28rpx;
  font-weight: 700;
}

.home-boundary__list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.home-boundary__item {
  color: #57534e;
  font-size: 24rpx;
  line-height: 1.65;
}

.home-secondary {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.home-secondary__link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 20rpx;
  background: #ffffff;
  color: #44403c;
  font-size: 27rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.home-secondary__arrow {
  color: #92400e;
}

.home-compliance {
  display: block;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #f5f5f4;
  color: #78716c;
  font-size: 22rpx;
  line-height: 1.75;
}

.session-hint {
  display: block;
  margin-bottom: 16rpx;
  color: #a16207;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: center;
}

@media (prefers-reduced-motion: reduce) {
  .home-hero__aura {
    animation: none;
  }
}
