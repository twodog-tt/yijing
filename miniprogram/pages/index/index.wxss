.page--home {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
  background:
    linear-gradient(180deg, rgba(185, 146, 85, 0.1) 0%, rgba(185, 146, 85, 0) 280rpx),
    #17130f;
  color: #f4ead8;
}

.home-hero {
  position: relative;
  overflow: hidden;
  margin-bottom: 34rpx;
  padding: 38rpx 30rpx 32rpx;
  border: 1rpx solid rgba(185, 146, 85, 0.32);
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(185, 146, 85, 0.16) 0%, rgba(185, 146, 85, 0) 42%),
    #211a14;
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.22);
}

.home-hero__eyebrow {
  display: block;
  color: #d6b06d;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.home-hero__title {
  display: block;
  margin-top: 14rpx;
  color: #fff7e6;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.45;
}

.home-hero__subtitle {
  display: block;
  margin-top: 12rpx;
  color: #e8d8bd;
  font-size: 27rpx;
  line-height: 1.65;
}

.home-hero__note {
  display: block;
  margin-top: 10rpx;
  color: #bcae98;
  font-size: 22rpx;
  line-height: 1.6;
}

.home-hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 26rpx;
}

.home-hero__button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 198rpx;
  min-height: 78rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.home-hero__button--primary {
  background: #d6b06d;
  color: #211a14;
}

.home-hero__button--secondary {
  border: 1rpx solid rgba(214, 176, 109, 0.45);
  color: #f4ead8;
}

.home-section {
  margin-bottom: 34rpx;
}

.home-section__header {
  margin-bottom: 18rpx;
}

.home-section__title {
  display: block;
  color: #fff7e6;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.45;
}

.home-section__desc {
  display: block;
  margin-top: 6rpx;
  color: #bcae98;
  font-size: 23rpx;
  line-height: 1.6;
}

.home-modules {
  margin-bottom: -18rpx;
}

.home-scene-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 118rpx;
  padding: 24rpx 24rpx 24rpx 26rpx;
  border: 1rpx solid rgba(185, 146, 85, 0.26);
  border-radius: 16rpx;
  background: rgba(255, 250, 240, 0.94);
  box-sizing: border-box;
}

.home-scene-card__main {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.home-scene-card__title {
  color: #292524;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.home-scene-card__subtitle {
  color: #57534e;
  font-size: 23rpx;
  line-height: 1.55;
}

.home-scene-card__button {
  flex: 0 0 auto;
  min-width: 92rpx;
  color: #7c4a16;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.45;
  text-align: right;
}

.home-planned-scenes {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.home-planned-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  border: 1rpx solid rgba(214, 176, 109, 0.2);
  border-radius: 999rpx;
  background: rgba(255, 247, 230, 0.08);
}

.home-planned-chip__title {
  color: #e8d8bd;
  font-size: 23rpx;
  line-height: 1.4;
}

.home-planned-chip__status {
  color: #a69274;
  font-size: 20rpx;
  line-height: 1.4;
}

.home-tool-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.home-tool-card {
  flex: 0 0 calc(50% - 7rpx);
  min-height: 96rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(214, 176, 109, 0.18);
  border-radius: 16rpx;
  background: rgba(255, 247, 230, 0.07);
  box-sizing: border-box;
}

.home-tool-card__title {
  display: block;
  color: #e8d8bd;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.45;
}

.home-tool-card__status {
  display: block;
  margin-top: 6rpx;
  color: #a69274;
  font-size: 21rpx;
  line-height: 1.4;
}

.home-boundary {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(214, 176, 109, 0.22);
  border-radius: 18rpx;
  background: rgba(255, 247, 230, 0.08);
}

.home-boundary__title {
  display: block;
  margin-bottom: 14rpx;
  color: #f4ead8;
  font-size: 26rpx;
  font-weight: 700;
}

.home-boundary__list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.home-boundary__item {
  color: #bcae98;
  font-size: 23rpx;
  line-height: 1.65;
}

.home-secondary {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.home-secondary__link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(214, 176, 109, 0.2);
  border-radius: 16rpx;
  background: rgba(255, 247, 230, 0.08);
  color: #f4ead8;
  font-size: 27rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.home-secondary__arrow {
  color: #d6b06d;
}

.home-compliance {
  display: block;
  padding: 24rpx;
  border-radius: 14rpx;
  background: rgba(0, 0, 0, 0.16);
  color: #a69274;
  font-size: 22rpx;
  line-height: 1.75;
}

.session-hint {
  display: block;
  margin-bottom: 16rpx;
  color: #d6b06d;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: center;
}
