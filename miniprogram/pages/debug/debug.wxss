.blocked,
.error {
  padding: 28rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.blocked {
  background: #f5f5f4;
  color: #57534e;
}

.error {
  margin-bottom: 24rpx;
  border: 1rpx solid #fecaca;
  background: #fef2f2;
  color: #991b1b;
}

.check-card {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 28rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 20rpx;
  background: #ffffff;
}

.check-content {
  flex: 1;
  min-width: 0;
}

.check-title,
.check-result,
.check-note {
  display: block;
}

.check-title {
  font-size: 28rpx;
  font-weight: 600;
}

.check-result {
  margin-top: 10rpx;
  color: #57534e;
  font-size: 23rpx;
  line-height: 1.55;
  word-break: break-all;
}

.check-note {
  margin-top: 8rpx;
  color: #a8a29e;
  font-size: 20rpx;
  line-height: 1.5;
}

.check-button {
  width: 150rpx;
  min-height: 88rpx;
  margin-left: 20rpx;
  padding: 0;
  border-radius: 14rpx;
  background: #292524;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 88rpx;
}

.check-button::after,
.clear-button::after {
  border: 0;
}

.clear-button {
  margin-top: 36rpx;
  border: 1rpx solid #d6d3d1;
  border-radius: 16rpx;
  background: #ffffff;
  color: #78716c;
  font-size: 24rpx;
}
