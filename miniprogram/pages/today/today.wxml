<casting-overlay visible="{{castingVisible}}" record="{{castingRecord}}" mode="today" bindfinish="handleCastingFinish" bindcancel="handleCastingCancel"></casting-overlay>

<view class="page">
  <navigator class="back-link" open-type="navigateBack" delta="1">← 返回</navigator>

  <view class="page-header">
    <text class="eyebrow">今日运势</text>
    <text class="page-title">今日一卦</text>
    <text class="today-date">{{todayDateDisplay}}</text>
    <text class="page-description">用传统易经卦象整理今天的状态、节奏、注意事项与行动建议。</text>
  </view>

  <error-state wx:if="{{error}}" visible="{{true}}" message="{{error}}" bindretry="handleStart"></error-state>

  <view class="card today-card">
    <text class="card-title">今天可以整理</text>
    <text class="topic">· 今日整体状态</text>
    <text class="topic">· 适合的行动节奏</text>
    <text class="topic">· 值得注意的风险</text>
    <text class="topic">· 情绪与自我反思提醒</text>
    <text class="card-text">同一匿名会话每天只生成一次，重复进入会打开当天已有记录。</text>
  </view>

  <loading-state wx:if="{{submitting}}" text="正在获取今日结果…"></loading-state>
  <button class="primary-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleStart">{{submitting ? '请稍候…' : '查看今日一卦'}}</button>

  <text class="disclaimer">内容仅供趣味解读和自我反思，不构成现实决策建议。</text>
</view>
