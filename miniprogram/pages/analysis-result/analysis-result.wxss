.result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
  color: #78716c;
  font-size: 24rpx;
}

.page-error {
  margin-top: 24rpx;
}

.error-link {
  margin-top: 24rpx;
}

.privacy-note {
  display: block;
  margin-top: 16rpx;
}

.pillar-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.pillar-item {
  padding: 20rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 16rpx;
  background: #fafaf9;
}

.pillar-label {
  display: block;
  color: #78716c;
  font-size: 22rpx;
}

.pillar-value {
  display: block;
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.pillar-unknown {
  display: block;
  margin-top: 10rpx;
  color: #78716c;
  font-size: 24rpx;
  line-height: 1.6;
}

.highlight-text {
  font-size: 36rpx;
  font-weight: 700;
}

.element-list {
  margin-top: 8rpx;
}

.element-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f4;
}

.element-row:last-child {
  border-bottom: 0;
}

.element-label {
  font-size: 28rpx;
}

.element-value {
  font-size: 28rpx;
  font-weight: 600;
}

.suggestion-list {
  margin-top: 8rpx;
}

.suggestion-item {
  display: block;
  margin-top: 12rpx;
  color: #57534e;
  font-size: 26rpx;
  line-height: 1.7;
}

.free-content {
  display: block;
  margin-top: 12rpx;
  color: #44403c;
  font-size: 28rpx;
  line-height: 1.8;
}

.full-section {
  margin-top: 8rpx;
}

.unlock-button {
  min-height: 96rpx;
  border: 1rpx solid #fcd34d;
  border-radius: 20rpx;
  background: #fffbeb;
  color: #78350f;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 96rpx;
}

.unlock-button::after {
  border: 0;
}

.unlock-hint {
  display: block;
  margin-top: 16rpx;
  color: #78716c;
  font-size: 22rpx;
  line-height: 1.7;
}

.full-card {
  margin-top: 24rpx;
}

.full-content {
  display: block;
  margin-top: 12rpx;
  color: #44403c;
  font-size: 28rpx;
  line-height: 1.8;
}

.pre-wrap {
  white-space: pre-wrap;
}

.delete-button {
  margin-top: 24rpx;
  color: #b91c1c;
}

.card-section {
  margin-top: 24rpx;
}

.card-button {
  width: 100%;
}

.card-hint {
  display: block;
  margin-top: 16rpx;
  color: #78716c;
  font-size: 22rpx;
  line-height: 1.7;
}
