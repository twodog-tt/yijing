.result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
  color: #78716c;
  font-size: 24rpx;
}

.page-header--result {
  position: relative;
  overflow: hidden;
}

.header-aura--subtle {
  position: absolute;
  top: -30rpx;
  right: -10rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(252, 211, 77, 0.14) 0%, rgba(252, 211, 77, 0) 70%);
  animation: header-aura-float 8s ease-in-out infinite;
  pointer-events: none;
}

.disclaimer--static {
  animation: none;
}

.element-row--wood .element-label,
.element-row--fire .element-label,
.element-row--earth .element-label,
.element-row--metal .element-label,
.element-row--water .element-label {
  animation: element-label-glow 8s ease-in-out infinite;
}

.element-row--wood .element-label { animation-delay: 0s; color: #166534; }
.element-row--fire .element-label { animation-delay: 1.6s; color: #c2410c; }
.element-row--earth .element-label { animation-delay: 3.2s; color: #92400e; }
.element-row--metal .element-label { animation-delay: 4.8s; color: #57534e; }
.element-row--water .element-label { animation-delay: 6.4s; color: #1d4ed8; }

.full-card--reveal {
  opacity: 0;
  transform: translateY(16rpx);
}

.full-card--visible {
  animation: full-fade-in 0.65s ease forwards;
}

.action-button--glow {
  animation: unlock-glow 1.4s ease-in-out infinite;
}

.share-section--ready .share-button--reveal {
  animation: share-emerge 0.55s ease 0.12s forwards;
  opacity: 0;
}

@keyframes header-aura-float {
  0%,
  100% {
    transform: translate(0, 0);
    opacity: 0.8;
  }

  50% {
    transform: translate(-10rpx, 8rpx);
    opacity: 1;
  }
}

@keyframes header-aura-float {
  0%,
  12%,
  100% {
    opacity: 0.72;
  }

  6% {
    opacity: 1;
  }
}

@keyframes full-fade-in {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes unlock-glow {
  0%,
  100% {
    box-shadow: 0 0 0 rgba(252, 211, 77, 0);
  }

  50% {
    box-shadow: 0 0 20rpx rgba(252, 211, 77, 0.35);
  }
}

@keyframes share-emerge {
  to {
    opacity: 1;
  }
}

.page-error {
  margin-top: 24rpx;
}

.error-link {
  margin-top: 24rpx;
}

.privacy-note {
  display: block;
  margin-top: 16rpx;
}

.pillar-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.pillar-item {
  padding: 20rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 16rpx;
  background: #fafaf9;
}

.pillar-label {
  display: block;
  color: #78716c;
  font-size: 22rpx;
}

.pillar-value {
  display: block;
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.pillar-unknown {
  display: block;
  margin-top: 10rpx;
  color: #78716c;
  font-size: 24rpx;
  line-height: 1.6;
}

.highlight-text {
  font-size: 36rpx;
  font-weight: 700;
}

.element-list {
  margin-top: 8rpx;
}

.element-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f4;
}

.element-row:last-child {
  border-bottom: 0;
}

.element-label {
  font-size: 28rpx;
}

.element-value {
  font-size: 28rpx;
  font-weight: 600;
}

.suggestion-list {
  margin-top: 8rpx;
}

.suggestion-item {
  display: block;
  margin-top: 12rpx;
  color: #57534e;
  font-size: 26rpx;
  line-height: 1.7;
}

.free-content {
  display: block;
  margin-top: 12rpx;
  color: #44403c;
  font-size: 28rpx;
  line-height: 1.8;
}

.full-section {
  margin-top: 8rpx;
}

.full-card {
  margin-top: 24rpx;
}

.full-content {
  display: block;
  margin-top: 12rpx;
  color: #44403c;
  font-size: 28rpx;
  line-height: 1.8;
}

.pre-wrap {
  white-space: pre-wrap;
}

.action-block {
  margin-top: 24rpx;
}

.action-button {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 20rpx;
  margin: 0;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.action-button::after {
  border: 0;
}

.action-button--unlock {
  border: 1rpx solid #fcd34d;
  background: #fffbeb;
  color: #78350f;
}

.action-button--card {
  border: 1rpx solid #292524;
  background: #292524;
  color: #ffffff;
}

.action-hint {
  display: block;
  margin-top: 16rpx;
  color: #78716c;
  font-size: 22rpx;
  line-height: 1.7;
}

.danger-section {
  margin-top: 48rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #e7e5e4;
}

.share-section {
  margin-top: 32rpx;
}

.share-hint {
  display: block;
  color: #78716c;
  font-size: 24rpx;
  line-height: 1.7;
}

.share-hint--secondary {
  margin-top: 16rpx;
  font-size: 22rpx;
}

.share-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.share-button {
  flex: 1;
  min-width: 0;
  margin: 0;
  padding: 0 14rpx;
}

@media (max-width: 340px) {
  .share-actions {
    flex-direction: column;
  }
}

.danger-label {
  display: block;
  margin-bottom: 16rpx;
  color: #a8a29e;
  font-size: 22rpx;
}

.danger-button {
  width: 100%;
  height: 76rpx;
  min-height: 76rpx;
  padding: 0 24rpx;
  margin: 0;
  border: 1rpx solid #fecaca;
  border-radius: 16rpx;
  background: #ffffff;
  color: #b91c1c;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.danger-button::after {
  border: 0;
}

@media (max-width: 340px) {
  .action-button {
    height: 84rpx;
    min-height: 84rpx;
    padding: 0 12rpx;
    font-size: 24rpx;
  }
}
