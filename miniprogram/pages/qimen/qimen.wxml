<view class="page">
  <navigator class="back-link" open-type="navigateBack" delta="1">← 返回</navigator>

  <view class="page-header page-header--qimen">
    <qimen-scan-grid variant="header"></qimen-scan-grid>
    <text class="eyebrow">奇门问事</text>
    <text class="page-title">基于传统奇门文化的局势梳理与行动节奏参考</text>
    <text class="page-description">{{methodNote}}</text>
  </view>

  <view class="card form-card">
    <text class="field-label">问事分类</text>
    <picker mode="selector" range="{{categories}}" range-key="label" value="{{categoryIndex}}" bindchange="onCategoryChange">
      <view class="picker-field picker-field--selected picker-field--category {{categoryPulse ? 'picker-field--pulse' : ''}}">
        <text>{{selectedCategoryLabel}}</text>
        <text>⌄</text>
      </view>
    </picker>

    <text class="field-label question-label">你的问题</text>
    <textarea
      class="question-input"
      value="{{question}}"
      maxlength="{{120}}"
      placeholder="例如：我最近适合如何安排这项计划的推进节奏？"
      bindinput="onQuestionInput"
    ></textarea>
    <text class="counter">{{questionLength}} / 120 字</text>

    <view class="safety-hint">请勿输入医疗、法律、投资、赌博、伤害自己或他人等问题。本工具不会处理此类内容。</view>

    <checkbox-group bindchange="onDisclaimerChange">
      <label class="agreement agreement--static">
        <checkbox value="confirmed" checked="{{confirmDisclaimer}}" color="#292524"></checkbox>
        <text>{{methodNote}}</text>
      </label>
    </checkbox-group>

    <text wx:if="{{fieldError}}" class="field-error">{{fieldError}}</text>
    <error-state wx:if="{{submitError}}" visible="{{true}}" message="{{submitError}}" show-retry="{{submitCanRetry}}" bindretry="submitForm"></error-state>

    <button
      class="primary-button submit-button {{submitting ? 'submit-button--loading' : ''}}"
      loading="{{submitting}}"
      disabled="{{submitting}}"
      bindtap="submitForm"
    >{{submitting ? '整理局势中…' : '生成奇门简析'}}</button>
  </view>

  <view class="history-section">
    <text class="section-title">最近记录</text>
    <loading-state wx:if="{{listLoading}}" text="正在加载最近记录…"></loading-state>
    <error-state wx:if="{{!listLoading && listError}}" visible="{{true}}" message="{{listError}}" bindretry="loadRecentList"></error-state>

    <view wx:if="{{!listLoading && !listError && recentList.length === 0}}" class="placeholder">暂无奇门问事记录，提交后将显示在这里。</view>

    <view wx:if="{{!listLoading && !listError && recentList.length > 0}}" class="history-list">
      <view class="history-item" wx:for="{{recentList}}" wx:key="id" data-id="{{item.id}}" bindtap="openRecord">
        <view class="history-main">
          <text class="history-title">{{item.moduleLabel}}</text>
          <text class="history-subtitle">{{item.subtitle}}</text>
        </view>
        <text class="history-time">{{item.createdAtDisplay}}</text>
      </view>
    </view>
  </view>

  <text class="disclaimer disclaimer--static">内容仅用于传统文化学习、自我反思和行动整理，不构成现实决策建议。</text>
</view>
