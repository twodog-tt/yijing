@import "../ask/ask.wxss";

.page-header--qimen {
  position: relative;
  margin-bottom: 8rpx;
}

.qimen-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qimen-hero__grid {
  display: flex;
  justify-content: center;
  width: 100%;
  margin-bottom: 20rpx;
}

.qimen-hero__copy {
  width: 100%;
  text-align: left;
}

.qimen-hero--result .qimen-hero__grid {
  margin-bottom: 16rpx;
}

.qimen-hero--result .result-meta {
  margin-top: 12rpx;
}

.picker-field--category {
  transition: border-color 0.28s ease, box-shadow 0.28s ease;
}

.picker-field--pulse {
  animation: category-select 0.55s ease;
}

.submit-button--loading {
  animation: submit-breathe 1.6s ease-in-out infinite;
}

.agreement--static,
.disclaimer--static {
  animation: none;
}

.question-label {
  margin-top: 32rpx;
}

.history-section {
  margin-top: 16rpx;
}

.history-list {
  margin-top: 8rpx;
}

.history-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 16rpx;
  padding: 28rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 20rpx;
  background: #ffffff;
}

.history-main {
  flex: 1;
  min-width: 0;
}

.history-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
}

.history-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #78716c;
  font-size: 22rpx;
}

.history-time {
  flex-shrink: 0;
  color: #a8a29e;
  font-size: 22rpx;
  white-space: nowrap;
}

@keyframes category-select {
  0% {
    border-color: #d6d3d1;
    box-shadow: 0 0 0 rgba(146, 64, 14, 0);
  }

  50% {
    border-color: #92400e;
    box-shadow: 0 0 16rpx rgba(146, 64, 14, 0.12);
  }

  100% {
    border-color: #d6d3d1;
    box-shadow: 0 0 0 rgba(146, 64, 14, 0);
  }
}

@keyframes submit-breathe {
  0%,
  100% {
    box-shadow: 0 0 0 rgba(41, 37, 36, 0);
  }

  50% {
    box-shadow: 0 0 24rpx rgba(41, 37, 36, 0.12);
  }
}
