<view class="page">
  <navigator class="back-link" open-type="navigateBack" delta="1">← 返回</navigator>

  <view class="page-header">
    <text class="eyebrow">八字简析</text>
    <text class="page-title">基于传统干支文化的性格与五行倾向学习</text>
    <text class="page-description">本功能采用简化干支文化规则，仅用于传统文化学习和自我反思，不等同于专业八字排盘，也不构成现实决策依据。</text>
  </view>

  <view class="card form-card">
    <text class="field-label">出生日期</text>
    <picker mode="date" value="{{birthDate}}" start="1900-01-01" end="{{maxDate}}" bindchange="onBirthDateChange">
      <view class="picker-field {{birthDate ? 'picker-field--selected' : ''}}">
        <text>{{birthDate || '请选择出生日期'}}</text>
        <text>⌄</text>
      </view>
    </picker>

    <checkbox-group class="unknown-group" bindchange="onHourUnknownChange">
      <label class="agreement">
        <checkbox value="unknown" checked="{{birthHourUnknown}}" color="#292524"></checkbox>
        <text>时辰未知（本次不生成时柱）</text>
      </label>
    </checkbox-group>

    <block wx:if="{{!birthHourUnknown}}">
      <text class="field-label hour-label">出生时辰</text>
      <picker mode="selector" range="{{hourBranches}}" range-key="label" value="{{hourBranchIndex >= 0 ? hourBranchIndex : 0}}" bindchange="onHourBranchChange">
        <view class="picker-field {{hourBranchIndex >= 0 ? 'picker-field--selected' : ''}}">
          <text>{{hourBranchIndex >= 0 ? hourBranches[hourBranchIndex].label : '请选择出生时辰'}}</text>
          <text>⌄</text>
        </view>
      </picker>
    </block>

    <checkbox-group bindchange="onDisclaimerChange">
      <label class="agreement">
        <checkbox value="confirmed" checked="{{confirmDisclaimer}}" color="#292524"></checkbox>
        <text>我理解本内容仅用于传统文化学习和自我反思，不作为现实决策依据。</text>
      </label>
    </checkbox-group>

    <text wx:if="{{fieldError}}" class="field-error">{{fieldError}}</text>
    <error-state wx:if="{{submitError}}" visible="{{true}}" message="{{submitError}}" show-retry="{{submitCanRetry}}" bindretry="submitForm"></error-state>

    <button class="primary-button submit-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitForm">{{submitting ? '提交中…' : '生成八字简析'}}</button>
  </view>

  <view class="history-section">
    <text class="section-title">最近记录</text>
    <loading-state wx:if="{{listLoading}}" text="正在加载最近记录…"></loading-state>
    <error-state wx:if="{{!listLoading && listError}}" visible="{{true}}" message="{{listError}}" bindretry="loadRecentList"></error-state>

    <view wx:if="{{!listLoading && !listError && recentList.length === 0}}" class="placeholder">暂无八字简析记录，提交后将显示在这里。</view>

    <view wx:if="{{!listLoading && !listError && recentList.length > 0}}" class="history-list">
      <view class="history-item" wx:for="{{recentList}}" wx:key="id" data-id="{{item.id}}" bindtap="openRecord">
        <view class="history-main">
          <text class="history-title">{{item.moduleLabel}}</text>
          <text class="history-subtitle">{{item.subtitle}}</text>
        </view>
        <text class="history-time">{{item.createdAtDisplay}}</text>
      </view>
    </view>
  </view>

  <text class="disclaimer">内容仅用于传统文化学习、自我反思和行动整理，不构成现实决策建议。</text>
</view>
