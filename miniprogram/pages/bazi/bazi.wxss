@import "../ask/ask.wxss";

.page-header--bazi {
  position: relative;
  overflow: hidden;
}

.header-aura {
  position: absolute;
  top: -40rpx;
  right: -20rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(252, 211, 77, 0.18) 0%, rgba(252, 211, 77, 0) 70%);
  animation: header-aura-float 8s ease-in-out infinite;
  pointer-events: none;
}

.agreement--static,
.disclaimer--static {
  animation: none;
}

.submit-button--loading {
  animation: submit-breathe 1.6s ease-in-out infinite;
}

.hour-label {
  margin-top: 32rpx;
}

.unknown-group {
  margin-top: 28rpx;
}

.history-section {
  margin-top: 16rpx;
}

.history-list {
  margin-top: 8rpx;
}

.history-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 16rpx;
  padding: 28rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 20rpx;
  background: #ffffff;
}

.history-main {
  flex: 1;
  min-width: 0;
}

.history-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
}

.history-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #78716c;
  font-size: 22rpx;
}

.history-time {
  flex-shrink: 0;
  color: #a8a29e;
  font-size: 22rpx;
  white-space: nowrap;
}

@keyframes header-aura-float {
  0%,
  100% {
    transform: translate(0, 0);
    opacity: 0.85;
  }

  50% {
    transform: translate(-12rpx, 10rpx);
    opacity: 1;
  }
}

@keyframes submit-breathe {
  0%,
  100% {
    box-shadow: 0 0 0 rgba(41, 37, 36, 0);
  }

  50% {
    box-shadow: 0 0 24rpx rgba(41, 37, 36, 0.12);
  }
}
