<view class="page">
  <navigator class="back-link" open-type="navigateBack" delta="1">← 返回</navigator>

  <view class="page-header">
    <text class="eyebrow">历史记录</text>
    <text class="page-title">回看你的思考记录</text>
    <text class="page-description">统一查看问事起卦、八字简析与奇门问事记录，下拉可刷新。</text>
  </view>

  <view class="filter-bar">
    <view
      wx:for="{{filters}}"
      wx:key="value"
      class="filter-chip {{activeFilter === item.value ? 'filter-chip--active' : ''}}"
      data-filter="{{item.value}}"
      bindtap="onFilterTap"
    >{{item.label}}</view>
  </view>

  <loading-state wx:if="{{loading}}" text="正在加载历史记录…"></loading-state>
  <error-state wx:if="{{error}}" visible="{{true}}" message="{{error}}" bindretry="loadHistory"></error-state>

  <view wx:if="{{!loading && !error && !visibleItems.length}}" class="empty-state">
    <text class="empty-title">{{emptyTitle}}</text>
    <text class="empty-description">{{emptyDescription}}</text>
    <navigator class="nav-link nav-link--primary empty-action" url="{{emptyActionUrl}}">{{emptyActionText}}</navigator>
  </view>

  <view wx:if="{{visibleItems.length}}" class="history-list">
    <view wx:for="{{visibleItems}}" wx:key="key" class="history-item">
      <view class="item-main" bindtap="openRecord" data-url="{{item.detailUrl}}">
        <view class="item-header">
          <text class="type-tag">{{item.typeLabel}}</text>
          <text class="status-tag">{{item.statusText}}</text>
        </view>
        <text class="item-title">{{item.title}}</text>
        <text class="item-summary">{{item.summary}}</text>
        <text class="created-at">{{item.createdAtDisplay}}</text>
      </view>
      <button
        wx:if="{{item.canDelete}}"
        class="delete-button"
        loading="{{deletingKey === item.key}}"
        disabled="{{deletingKey === item.key}}"
        catchtap="confirmDelete"
        data-id="{{item.id}}"
        data-type="{{item.recordType}}"
      >删除</button>
    </view>
  </view>

  <loading-state wx:if="{{loadingMore}}" text="正在加载更多…"></loading-state>
  <button wx:if="{{hasMore && !loadingMore && visibleItems.length}}" class="secondary-button load-more" bindtap="loadMore">加载更多</button>
  <text wx:if="{{visibleItems.length && !hasMore && !loading}}" class="list-end">没有更多记录了</text>
</view>
