.page-header .eyebrow {
  color: #b99255;
}

.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 26rpx;
}

.filter-chip {
  padding: 10rpx 22rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 999rpx;
  background: #ffffff;
  color: #57534e;
  font-size: 23rpx;
}

.filter-chip--active {
  border-color: #d6b06d;
  background: #fff7e6;
  color: #7c4a16;
  font-weight: 600;
}

.empty-state {
  padding: 52rpx 32rpx;
  border: 2rpx dashed #e7d8b8;
  border-radius: 24rpx;
  background: #fffdf8;
  text-align: center;
}

.empty-title,
.empty-description,
.item-title,
.item-summary,
.created-at,
.list-end {
  display: block;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
}

.empty-description {
  margin-top: 16rpx;
  color: #78716c;
  font-size: 24rpx;
  line-height: 1.7;
}

.empty-action {
  margin-top: 32rpx;
  border-color: #d6b06d;
  background: #fff7e6;
  color: #7c4a16;
}

.empty-action.nav-link--primary {
  border-color: #d6b06d;
  background: #fff7e6;
  color: #7c4a16;
}

.history-item {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 28rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(41, 37, 36, 0.04);
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.type-tag {
  color: #7c4a16;
  font-size: 23rpx;
  font-weight: 600;
}

.status-tag {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #faf5eb;
  color: #78716c;
  font-size: 20rpx;
}

.item-title {
  margin-top: 18rpx;
  color: #292524;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.6;
  word-break: break-all;
}

.item-summary {
  margin-top: 12rpx;
  color: #57534e;
  font-size: 24rpx;
  line-height: 1.6;
  word-break: break-all;
}

.created-at {
  margin-top: 12rpx;
  color: #a8a29e;
  font-size: 21rpx;
}

.delete-button {
  flex-shrink: 0;
  align-self: center;
  min-width: 112rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 20rpx;
  border: 1rpx solid #eadfcb;
  border-radius: 999rpx;
  background: #fffdf8;
  color: #78716c;
  font-size: 22rpx;
  line-height: 64rpx;
}

.delete-button::after {
  border: none;
}

.load-more {
  margin-top: 24rpx;
}

.list-end {
  padding: 28rpx 0;
  color: #a8a29e;
  font-size: 22rpx;
  text-align: center;
}
