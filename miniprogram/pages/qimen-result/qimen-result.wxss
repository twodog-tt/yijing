.result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
  color: #78716c;
  font-size: 24rpx;
}

.page-error {
  margin-top: 24rpx;
}

.error-link {
  margin-top: 24rpx;
}

.privacy-note {
  display: block;
  margin-top: 16rpx;
}

.bullet-list {
  margin-top: 8rpx;
}

.bullet-item {
  display: block;
  margin-top: 12rpx;
  color: #57534e;
  font-size: 26rpx;
  line-height: 1.7;
}

.free-content {
  display: block;
  margin-top: 12rpx;
  color: #44403c;
  font-size: 28rpx;
  line-height: 1.8;
}

.pre-wrap {
  white-space: pre-wrap;
}

.danger-section {
  margin-top: 48rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #e7e5e4;
}

.danger-label {
  display: block;
  margin-bottom: 16rpx;
  color: #a8a29e;
  font-size: 22rpx;
}

.danger-button {
  width: 100%;
  height: 76rpx;
  min-height: 76rpx;
  padding: 0 24rpx;
  margin: 0;
  border: 1rpx solid #fecaca;
  border-radius: 16rpx;
  background: #ffffff;
  color: #b91c1c;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.danger-button::after {
  border: 0;
}
