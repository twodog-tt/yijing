.result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  color: #78716c;
  font-size: 24rpx;
}

.page-header--result {
  position: relative;
}

.qimen-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qimen-hero__grid {
  display: flex;
  justify-content: center;
  width: 100%;
  margin-bottom: 16rpx;
}

.qimen-hero__copy {
  width: 100%;
  text-align: left;
}

.qimen-hero--result .result-meta {
  margin-top: 12rpx;
}

.disclaimer--static {
  animation: none;
}

.full-card--reveal {
  opacity: 0;
  transform: translateY(16rpx);
}

.full-card--visible {
  animation: full-fade-in 0.65s ease forwards;
}

.action-button--glow {
  animation: unlock-glow 1.4s ease-in-out infinite;
}

.share-section--ready .share-button--reveal {
  animation: share-emerge 0.55s ease 0.12s forwards;
  opacity: 0;
}

@keyframes full-fade-in {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes unlock-glow {
  0%,
  100% {
    box-shadow: 0 0 0 rgba(252, 211, 77, 0);
  }

  50% {
    box-shadow: 0 0 20rpx rgba(252, 211, 77, 0.35);
  }
}

@keyframes share-emerge {
  to {
    opacity: 1;
  }
}

.page-error {
  margin-top: 24rpx;
}

.error-link {
  margin-top: 24rpx;
}

.privacy-note {
  display: block;
  margin-top: 16rpx;
}

.bullet-list {
  margin-top: 8rpx;
}

.bullet-item {
  display: block;
  margin-top: 12rpx;
  color: #57534e;
  font-size: 26rpx;
  line-height: 1.7;
}

.free-content {
  display: block;
  margin-top: 12rpx;
  color: #44403c;
  font-size: 28rpx;
  line-height: 1.8;
}

.pre-wrap {
  white-space: pre-wrap;
}

.action-block {
  margin-top: 24rpx;
}

.action-button {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 20rpx;
  margin: 0;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.action-button::after {
  border: 0;
}

.action-button--unlock {
  border: 1rpx solid #fcd34d;
  background: #fffbeb;
  color: #78350f;
}

.action-hint {
  display: block;
  margin-top: 16rpx;
  color: #78716c;
  font-size: 22rpx;
  line-height: 1.7;
}

.full-content {
  display: block;
  margin-top: 12rpx;
  color: #292524;
  font-size: 28rpx;
  line-height: 1.8;
}

.full-section {
  margin-top: 16rpx;
}

.share-section {
  margin-top: 32rpx;
}

.share-hint {
  display: block;
  color: #78716c;
  font-size: 24rpx;
  line-height: 1.7;
}

.share-hint--secondary {
  margin-top: 16rpx;
  font-size: 22rpx;
}

.share-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.share-button {
  flex: 1;
  min-width: 0;
  margin: 0;
  padding: 0 14rpx;
}

@media (max-width: 340px) {
  .share-actions {
    flex-direction: column;
  }
}

.danger-section {
  margin-top: 48rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #e7e5e4;
}

.danger-label {
  display: block;
  margin-bottom: 16rpx;
  color: #a8a29e;
  font-size: 22rpx;
}

.danger-button {
  width: 100%;
  height: 76rpx;
  min-height: 76rpx;
  padding: 0 24rpx;
  margin: 0;
  border: 1rpx solid #fecaca;
  border-radius: 16rpx;
  background: #ffffff;
  color: #b91c1c;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.danger-button::after {
  border: 0;
}
