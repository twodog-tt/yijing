.page-error {
  padding-top: 32rpx;
}

.error-link {
  margin-top: 24rpx;
}

.result-meta {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 18rpx;
  color: #78716c;
  font-size: 22rpx;
}

.result-summary {
  padding-top: 18rpx;
  padding-bottom: 18rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f4;
  color: #44403c;
  font-size: 24rpx;
}

.summary-row:last-child {
  border-bottom: 0;
}

.summary-label {
  color: #a8a29e;
}

.hexagram-list hexagram-card,
.hexagram-list line-chart {
  display: block;
  margin-bottom: 20rpx;
}

line-chart {
  display: block;
  margin-bottom: 24rpx;
}

.free-card {
  margin-top: 24rpx;
}

.free-content {
  color: #57534e;
  font-size: 26rpx;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.full-section {
  margin-top: 32rpx;
}

.unlock-button {
  min-height: 96rpx;
  border: 1rpx solid #fcd34d;
  border-radius: 20rpx;
  background: #fffbeb;
  color: #78350f;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 96rpx;
}

.unlock-button::after {
  border: 0;
}

.retry-full {
  margin-top: 20rpx;
}

.provider-hint {
  display: block;
  margin-bottom: 16rpx;
  color: #a8a29e;
  font-size: 21rpx;
  text-align: right;
}
