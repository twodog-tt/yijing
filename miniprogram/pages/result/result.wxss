.page-error {
  padding-top: 32rpx;
}

.error-link {
  margin-top: 24rpx;
}

.result-header {
  margin-bottom: 24rpx;
}

.result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
  color: #92400e;
  font-size: 22rpx;
}

.result-meta text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fffbeb;
  line-height: 1.35;
}

.result-question-card {
  border-color: #fde68a;
  background: #fffdf8;
}

.result-question-card__label,
.result-question-card__text {
  display: block;
}

.result-question-card__label {
  color: #92400e;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.result-question-card__text {
  margin-top: 12rpx;
  color: #292524;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.65;
  word-break: break-all;
}

.result-summary {
  padding-top: 18rpx;
  padding-bottom: 18rpx;
}

.summary-row {
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f4;
  color: #44403c;
  font-size: 24rpx;
  line-height: 1.55;
}

.summary-row:last-child {
  border-bottom: 0;
}

.summary-label {
  flex: 0 0 auto;
  color: #a8a29e;
}

.summary-row text:last-child {
  text-align: right;
  word-break: break-all;
}

.hexagram-list hexagram-card,
.hexagram-list line-chart {
  display: block;
  margin-bottom: 20rpx;
}

line-chart {
  display: block;
  margin-bottom: 24rpx;
}

.free-card {
  margin-top: 24rpx;
  border-color: #f1f5f9;
  background: #fffefe;
}

.free-content {
  color: #44403c;
  font-size: 27rpx;
  line-height: 1.85;
  white-space: pre-wrap;
  word-break: break-all;
}

.full-section {
  margin-top: 32rpx;
}

.unlock-button {
  min-height: 96rpx;
  border: 1rpx solid #fcd34d;
  border-radius: 20rpx;
  background: #292524;
  color: #fef3c7;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 96rpx;
  box-shadow: 0 10rpx 24rpx rgba(41, 37, 36, 0.16);
}

.unlock-button::after {
  border: 0;
}

.unlock-hint {
  display: block;
  margin-top: 16rpx;
  color: #78716c;
  font-size: 22rpx;
  line-height: 1.7;
}

.dev-ad-tools {
  margin-top: 20rpx;
  padding: 20rpx;
  border: 1rpx dashed #d6d3d1;
  border-radius: 16rpx;
  background: #fafaf9;
}

.dev-ad-label {
  display: block;
  color: #a8a29e;
  font-size: 22rpx;
}

.dev-ad-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.dev-ad-button {
  flex: 1;
  margin: 0;
}

.retry-full {
  margin-top: 20rpx;
}

.provider-hint {
  display: block;
  margin-bottom: 16rpx;
  color: #a8a29e;
  font-size: 21rpx;
  text-align: right;
}

.share-section {
  margin-top: 32rpx;
  border-color: #e7e5e4;
  background: #fafaf9;
}

.share-hint {
  display: block;
  color: #78716c;
  font-size: 24rpx;
  line-height: 1.7;
  word-break: break-all;
}

.share-hint--secondary {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #a8a29e;
}

.share-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.share-button {
  flex: 1;
  min-width: 0;
  margin: 0;
  padding: 0 14rpx;
}

@media (max-width: 340px) {
  .share-actions {
    flex-direction: column;
  }
}
