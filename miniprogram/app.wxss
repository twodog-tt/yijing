page {
  min-height: 100%;
  background: #faf8f3;
  color: #292524;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 32rpx;
}

.eyebrow {
  color: #92400e;
  font-size: 24rpx;
  letter-spacing: 4rpx;
}

.page-title {
  display: block;
  margin-top: 16rpx;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.page-description {
  display: block;
  margin-top: 16rpx;
  color: #57534e;
  font-size: 28rpx;
  line-height: 1.75;
  word-break: break-all;
}

.card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(41, 37, 36, 0.05);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
}

.card-text {
  display: block;
  margin-top: 12rpx;
  color: #57534e;
  font-size: 26rpx;
  line-height: 1.7;
  word-break: break-all;
}

.nav-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  margin-bottom: 20rpx;
  padding: 0 28rpx;
  border: 1rpx solid #d6d3d1;
  border-radius: 20rpx;
  background: #ffffff;
  color: #292524;
  font-size: 28rpx;
  font-weight: 600;
  box-sizing: border-box;
  word-break: break-all;
}

.nav-link--primary {
  border-color: #292524;
  background: #292524;
  color: #ffffff;
}

.back-link {
  display: inline-flex;
  align-items: center;
  min-height: 88rpx;
  color: #92400e;
  font-size: 26rpx;
}

.placeholder {
  padding: 40rpx 28rpx;
  border: 2rpx dashed #d6d3d1;
  border-radius: 20rpx;
  color: #78716c;
  font-size: 26rpx;
  line-height: 1.7;
  text-align: center;
}

.disclaimer {
  display: block;
  margin-top: 32rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #f5f5f4;
  color: #78716c;
  font-size: 22rpx;
  line-height: 1.7;
  word-break: break-all;
}

.primary-button,
.secondary-button {
  min-height: 96rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 96rpx;
}

.primary-button {
  background: #292524;
  color: #ffffff;
}

.secondary-button {
  border: 1rpx solid #d6d3d1;
  background: #ffffff;
  color: #44403c;
}

.primary-button::after,
.secondary-button::after {
  border: 0;
}

.section-title {
  display: block;
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.muted-text {
  color: #78716c;
  font-size: 24rpx;
  line-height: 1.65;
}
