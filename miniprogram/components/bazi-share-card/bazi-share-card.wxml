<canvas type="2d" id="baziShareCardCanvas" class="card-canvas"></canvas>

<view wx:if="{{previewVisible}}" class="card-overlay" catchtouchmove="preventTouchMove" bindtap="closePreview">
  <view class="card-dialog" catchtap="preventTouchMove">
    <view class="card-dialog__header">
      <text class="card-dialog__title">结果卡片</text>
      <text class="card-dialog__hint">卡片不包含出生信息、完整报告或小程序码</text>
    </view>
    <scroll-view class="card-preview" scroll-y="true">
      <image class="card-image" src="{{imagePath}}" mode="widthFix"></image>
    </scroll-view>
    <view class="card-actions">
      <button class="card-button card-button--secondary" bindtap="closePreview">关闭</button>
      <button class="card-button card-button--primary" loading="{{saving}}" disabled="{{saving}}" bindtap="saveCard">保存到相册</button>
    </view>
  </view>
</view>
