.overlay {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
  padding: calc(36rpx + env(safe-area-inset-top)) 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(28, 25, 23, 0.97);
  color: #ffffff;
  box-sizing: border-box;
  overflow: hidden;
}

.content {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
}

.header {
  text-align: center;
}

.eyebrow,
.title,
.subtitle,
.progress,
.line-value,
.line-meta,
.summary-label,
.summary-name,
.moving-text,
.disclaimer {
  display: block;
}

.eyebrow {
  color: #fcd34d;
  font-size: 21rpx;
  letter-spacing: 6rpx;
}

.title {
  margin-top: 14rpx;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
}

.subtitle {
  min-height: 40rpx;
  margin-top: 10rpx;
  color: #d6d3d1;
  font-size: 23rpx;
  line-height: 1.6;
}

.progress {
  margin-top: 10rpx;
  color: #fbbf24;
  font-size: 21rpx;
}

.stage {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  min-height: 0;
  padding: 20rpx 0;
  overflow-y: auto;
}

.preparing {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #a8a29e;
  font-size: 23rpx;
}

.prepare-ring {
  width: 66rpx;
  height: 66rpx;
  margin-bottom: 24rpx;
  border: 5rpx solid #57534e;
  border-top-color: #fbbf24;
  border-radius: 50%;
  animation: spin 0.75s linear infinite;
}

.active-card {
  margin-bottom: 24rpx;
  padding: 22rpx;
  border: 1rpx solid #78716c;
  border-radius: 20rpx;
  background: rgba(68, 64, 60, 0.72);
  text-align: center;
}

.coins {
  display: flex;
  justify-content: center;
  margin-bottom: 14rpx;
}

.coin {
  width: 48rpx;
  height: 48rpx;
  margin: 0 9rpx;
  border: 4rpx solid #fbbf24;
  border-radius: 50%;
  background: #92400e;
  box-shadow: inset 0 0 0 5rpx #d97706;
}

.coin--active {
  animation: coin-pulse 0.34s ease-in-out infinite alternate;
}

.coin--delay-one {
  animation-delay: 0.08s;
}

.coin--delay-two {
  animation-delay: 0.16s;
}

.line-value {
  color: #fef3c7;
  font-size: 27rpx;
  font-weight: 600;
}

.line-meta {
  margin-top: 6rpx;
  color: #d6d3d1;
  font-size: 22rpx;
}

.line-stack {
  display: flex;
  flex-direction: column-reverse;
  padding: 18rpx 16rpx;
  border: 1rpx solid #57534e;
  border-radius: 20rpx;
  background: rgba(41, 37, 36, 0.74);
}

.line-slot {
  display: flex;
  align-items: center;
  min-height: 50rpx;
  padding: 5rpx 8rpx;
  border-radius: 10rpx;
  box-sizing: border-box;
}

.line-slot--active {
  background: rgba(217, 119, 6, 0.18);
}

.position {
  width: 72rpx;
  color: #a8a29e;
  font-size: 20rpx;
}

.bar-wrap {
  flex: 1;
  margin: 0 16rpx;
  transition: opacity 0.2s ease;
}

.bar-wrap--pending {
  opacity: 0.16;
}

.yang-bar,
.yin-part,
.pending-bar {
  height: 11rpx;
  border-radius: 3rpx;
  background: #f5f5f4;
}

.pending-bar {
  background: #78716c;
}

.yin-bar {
  display: flex;
  justify-content: space-between;
}

.yin-part {
  width: 43%;
}

.bar--moving {
  background: #f59e0b;
}

.slot-meta {
  width: 112rpx;
  color: #a8a29e;
  font-size: 19rpx;
  text-align: right;
}

.hexagram-summary {
  margin-top: 18rpx;
  padding: 26rpx;
  border: 1rpx solid #57534e;
  border-radius: 22rpx;
  background: rgba(41, 37, 36, 0.76);
}

.summary-item {
  text-align: center;
}

.summary-item--changed {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #57534e;
}

.summary-label {
  color: #fbbf24;
  font-size: 21rpx;
}

.summary-name {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.moving-text {
  margin-top: 8rpx;
  color: #d6d3d1;
  font-size: 21rpx;
}

.footer {
  text-align: center;
}

.disclaimer {
  color: #78716c;
  font-size: 19rpx;
  line-height: 1.55;
}

.skip-button {
  min-height: 88rpx;
  margin-top: 12rpx;
  padding: 0 26rpx;
  border: 0;
  border-radius: 999rpx;
  background: transparent;
  color: #d6d3d1;
  font-size: 22rpx;
  line-height: 88rpx;
}

.skip-button::after {
  border: 0;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes coin-pulse {
  from { transform: translateY(0) rotateY(0deg); opacity: 0.72; }
  to { transform: translateY(-8rpx) rotateY(180deg); opacity: 1; }
}
