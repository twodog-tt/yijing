.report {
  box-sizing: border-box;
}

.section-title,
.label,
.summary,
.title,
.content,
.list-item,
.report-disclaimer,
.empty {
  display: block;
}

.section-title {
  margin-bottom: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.summary-card,
.content-card {
  margin-bottom: 20rpx;
  padding: 30rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 20rpx;
  background: #ffffff;
}

.summary-card {
  border-color: #fde68a;
  background: #fffbeb;
}

.label {
  color: #92400e;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.summary {
  margin-top: 12rpx;
  font-size: 29rpx;
  font-weight: 600;
  line-height: 1.65;
  word-break: break-all;
}

.title {
  font-size: 27rpx;
  font-weight: 600;
}

.content,
.list-item {
  margin-top: 14rpx;
  color: #57534e;
  font-size: 25rpx;
  line-height: 1.75;
  word-break: break-all;
}

.report-disclaimer,
.empty {
  padding: 24rpx;
  border-radius: 16rpx;
  background: #f5f5f4;
  color: #78716c;
  font-size: 22rpx;
  line-height: 1.7;
  word-break: break-all;
}
