.chart {
  padding: 32rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.title {
  font-size: 28rpx;
  font-weight: 600;
}

.empty {
  margin-top: 24rpx;
  color: #a8a29e;
  font-size: 24rpx;
  text-align: center;
}

.line-list {
  margin-top: 24rpx;
}

.line-item {
  display: flex;
  align-items: center;
  min-height: 64rpx;
  margin-bottom: 8rpx;
  padding: 8rpx 10rpx;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.line-item--moving {
  background: #fffbeb;
}

.position {
  width: 74rpx;
  color: #78716c;
  font-size: 22rpx;
}

.line-symbol {
  flex: 1;
  margin: 0 20rpx;
}

.yang-line,
.yin-part {
  height: 14rpx;
  border-radius: 4rpx;
  background: #292524;
}

.yin-line {
  display: flex;
  justify-content: space-between;
}

.yin-part {
  width: 44%;
}

.bar--moving {
  background: #d97706;
}

.meaning {
  width: 100rpx;
  color: #57534e;
  font-size: 22rpx;
  text-align: right;
}

.direction {
  display: block;
  margin-top: 18rpx;
  color: #a8a29e;
  font-size: 20rpx;
  text-align: center;
}
