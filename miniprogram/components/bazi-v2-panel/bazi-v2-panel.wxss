.bazi-v2-panel {
  margin-top: 0;
}

.bazi-v2-panel__title {
  display: block;
  color: #fde68a;
  font-size: 30rpx;
  font-weight: 600;
}

.bazi-v2-panel__note {
  display: block;
  margin-top: 12rpx;
  color: #d6d3d1;
  font-size: 24rpx;
  line-height: 1.7;
}

.bazi-v2-panel__section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(252, 211, 77, 0.14);
}

.bazi-v2-panel__section--boundary {
  padding-bottom: 4rpx;
}

.bazi-v2-panel__section-title {
  display: block;
  color: #fcd34d;
  font-size: 24rpx;
  font-weight: 600;
}

.bazi-v2-panel__pillar-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.bazi-v2-panel__pillar {
  padding: 16rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(252, 211, 77, 0.18);
  background: rgba(28, 25, 23, 0.55);
}

.bazi-v2-panel__pillar-label {
  display: block;
  color: #a8a29e;
  font-size: 20rpx;
}

.bazi-v2-panel__pillar-value {
  display: block;
  margin-top: 8rpx;
  color: #fafaf9;
  font-size: 28rpx;
  font-weight: 600;
}

.bazi-v2-panel__pillar-unknown {
  display: block;
  margin-top: 8rpx;
  color: #a8a29e;
  font-size: 22rpx;
  line-height: 1.5;
}

.bazi-v2-panel__kv-list {
  margin-top: 12rpx;
}

.bazi-v2-panel__kv {
  display: block;
  margin-top: 10rpx;
  color: #e7e5e4;
  font-size: 24rpx;
  line-height: 1.6;
}

.bazi-v2-panel__kv--muted {
  color: #a8a29e;
}

.bazi-v2-panel__element-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 16rpx;
}

.bazi-v2-panel__element {
  padding: 12rpx 6rpx;
  border-radius: 12rpx;
  text-align: center;
  background: rgba(28, 25, 23, 0.55);
  border: 1rpx solid rgba(252, 211, 77, 0.12);
}

.bazi-v2-panel__element-label {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
}

.bazi-v2-panel__element-value {
  display: block;
  margin-top: 6rpx;
  color: #fafaf9;
  font-size: 26rpx;
  font-weight: 600;
}

.bazi-v2-panel__element--wood .bazi-v2-panel__element-label { color: #86efac; }
.bazi-v2-panel__element--fire .bazi-v2-panel__element-label { color: #fdba74; }
.bazi-v2-panel__element--earth .bazi-v2-panel__element-label { color: #fcd34d; }
.bazi-v2-panel__element--metal .bazi-v2-panel__element-label { color: #d6d3d1; }
.bazi-v2-panel__element--water .bazi-v2-panel__element-label { color: #93c5fd; }

.bazi-v2-panel__hint {
  display: block;
  margin-top: 14rpx;
  color: #a8a29e;
  font-size: 22rpx;
  line-height: 1.6;
}
