<view class="bazi-v2-panel" wx:if="{{v2 && v2.isBaziV2}}">
  <text class="bazi-v2-panel__title">节气口径预览</text>
  <text class="bazi-v2-panel__note">{{v2.previewNote}}</text>

  <view class="bazi-v2-panel__section">
    <text class="bazi-v2-panel__section-title">四柱结构</text>
    <view class="bazi-v2-panel__pillar-grid">
      <view class="bazi-v2-panel__pillar">
        <text class="bazi-v2-panel__pillar-label">年柱</text>
        <text class="bazi-v2-panel__pillar-value">{{v2.pillarsV2View.year}}</text>
      </view>
      <view class="bazi-v2-panel__pillar">
        <text class="bazi-v2-panel__pillar-label">月柱</text>
        <text class="bazi-v2-panel__pillar-value">{{v2.pillarsV2View.month}}</text>
      </view>
      <view class="bazi-v2-panel__pillar">
        <text class="bazi-v2-panel__pillar-label">日柱</text>
        <text class="bazi-v2-panel__pillar-value">{{v2.pillarsV2View.day}}</text>
      </view>
      <view class="bazi-v2-panel__pillar">
        <text class="bazi-v2-panel__pillar-label">时柱</text>
        <text wx:if="{{!v2.pillarsV2View.hourUnknown}}" class="bazi-v2-panel__pillar-value">{{v2.pillarsV2View.hour}}</text>
        <text wx:else class="bazi-v2-panel__pillar-unknown">未知时辰，未生成时柱</text>
      </view>
    </view>
  </view>

  <view class="bazi-v2-panel__section">
    <text class="bazi-v2-panel__section-title">节气口径</text>
    <view class="bazi-v2-panel__kv-list">
      <text class="bazi-v2-panel__kv">年界 · {{v2.calendarBasisView.yearBoundaryLabel}}</text>
      <text class="bazi-v2-panel__kv">月界 · {{v2.calendarBasisView.monthBoundaryLabel}}</text>
      <text class="bazi-v2-panel__kv">日柱口径 · {{v2.calendarBasisView.dayPillarBasisLabel}}</text>
      <text class="bazi-v2-panel__kv">真太阳时 · {{v2.calendarBasisView.trueSolarTimeLabel}}</text>
      <text wx:if="{{v2.calendarBasisView.note}}" class="bazi-v2-panel__kv bazi-v2-panel__kv--muted">{{v2.calendarBasisView.note}}</text>
    </view>
  </view>

  <view class="bazi-v2-panel__section">
    <text class="bazi-v2-panel__section-title">五行结构</text>
    <view class="bazi-v2-panel__element-grid">
      <view class="bazi-v2-panel__element bazi-v2-panel__element--wood">
        <text class="bazi-v2-panel__element-label">木</text>
        <text class="bazi-v2-panel__element-value">{{v2.fiveElementsView.wood}}</text>
      </view>
      <view class="bazi-v2-panel__element bazi-v2-panel__element--fire">
        <text class="bazi-v2-panel__element-label">火</text>
        <text class="bazi-v2-panel__element-value">{{v2.fiveElementsView.fire}}</text>
      </view>
      <view class="bazi-v2-panel__element bazi-v2-panel__element--earth">
        <text class="bazi-v2-panel__element-label">土</text>
        <text class="bazi-v2-panel__element-value">{{v2.fiveElementsView.earth}}</text>
      </view>
      <view class="bazi-v2-panel__element bazi-v2-panel__element--metal">
        <text class="bazi-v2-panel__element-label">金</text>
        <text class="bazi-v2-panel__element-value">{{v2.fiveElementsView.metal}}</text>
      </view>
      <view class="bazi-v2-panel__element bazi-v2-panel__element--water">
        <text class="bazi-v2-panel__element-label">水</text>
        <text class="bazi-v2-panel__element-value">{{v2.fiveElementsView.water}}</text>
      </view>
    </view>
    <text class="bazi-v2-panel__hint">以上仅为结构化观察，不作强吉凶判断。</text>
  </view>

  <view wx:if="{{v2.compatibilityNote}}" class="bazi-v2-panel__section">
    <text class="bazi-v2-panel__section-title">兼容说明</text>
    <text class="bazi-v2-panel__kv">{{v2.compatibilityNote}}</text>
  </view>

  <view class="bazi-v2-panel__section bazi-v2-panel__section--boundary">
    <text class="bazi-v2-panel__section-title">边界说明</text>
    <view class="bazi-v2-panel__kv-list">
      <text class="bazi-v2-panel__kv" wx:for="{{v2.boundaryNotes}}" wx:key="*this">· {{item}}</text>
    </view>
    <view wx:if="{{v2.limits.length}}" class="bazi-v2-panel__kv-list">
      <text class="bazi-v2-panel__kv bazi-v2-panel__kv--muted" wx:for="{{v2.limits}}" wx:key="*this">· {{item}}</text>
    </view>
  </view>
</view>
