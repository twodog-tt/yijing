.qimen-scan-grid {
  position: relative;
  flex-shrink: 0;
  overflow: visible;
}

.qimen-scan-grid--hero {
  width: 168rpx;
  height: 168rpx;
  margin: 0 auto 8rpx;
}

.qimen-scan-grid--compact {
  width: 112rpx;
  height: 112rpx;
  margin: 0;
}

.qimen-scan-grid__glow {
  position: absolute;
  inset: -16rpx;
  z-index: 0;
  border-radius: 28rpx;
  background: radial-gradient(
    circle at 50% 42%,
    rgba(252, 211, 77, 0.32) 0%,
    rgba(254, 243, 199, 0.12) 52%,
    rgba(252, 211, 77, 0) 72%
  );
  pointer-events: none;
}

.qimen-scan-grid--compact .qimen-scan-grid__glow {
  inset: -8rpx;
  border-radius: 18rpx;
}

.qimen-scan-grid__cells {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 7rpx;
  width: 100%;
  height: 100%;
  padding: 12rpx;
  box-sizing: border-box;
  overflow: hidden;
  border: 1.5rpx solid rgba(252, 211, 77, 0.5);
  border-radius: 20rpx;
  background: linear-gradient(
    145deg,
    rgba(255, 251, 235, 0.96) 0%,
    rgba(250, 250, 249, 0.88) 100%
  );
  box-shadow: 0 10rpx 28rpx rgba(146, 64, 14, 0.1);
}

.qimen-scan-grid--compact .qimen-scan-grid__cells {
  gap: 4rpx;
  padding: 8rpx;
  border-radius: 14rpx;
  box-shadow: 0 4rpx 12rpx rgba(146, 64, 14, 0.08);
}

.qimen-scan-grid__cell {
  border: 1.5rpx solid rgba(146, 64, 14, 0.28);
  border-radius: 9rpx;
  background: rgba(255, 255, 255, 0.42);
  animation: qimen-cell-glow 5.2s ease-in-out infinite;
  animation-delay: calc(var(--cell-i, 0) * 0.38s);
}

.qimen-scan-grid__scan-line {
  position: absolute;
  left: 8%;
  z-index: 4;
  width: 84%;
  height: 3rpx;
  border-radius: 999rpx;
  background: linear-gradient(
    90deg,
    rgba(252, 211, 77, 0) 0%,
    rgba(252, 211, 77, 0.75) 50%,
    rgba(252, 211, 77, 0) 100%
  );
  box-shadow: 0 0 10rpx rgba(252, 211, 77, 0.35);
  animation: qimen-scan-line-v 5.2s ease-in-out infinite;
  pointer-events: none;
}

.qimen-scan-grid__scan-diagonal {
  position: absolute;
  top: -30%;
  left: -35%;
  z-index: 3;
  width: 170%;
  height: 38%;
  background: linear-gradient(
    135deg,
    rgba(252, 211, 77, 0) 0%,
    rgba(252, 211, 77, 0.22) 48%,
    rgba(252, 211, 77, 0) 100%
  );
  transform: rotate(-12deg);
  animation: qimen-scan-diagonal 5.2s ease-in-out infinite;
  animation-delay: 2.4s;
  pointer-events: none;
}

.qimen-scan-grid__dot {
  position: absolute;
  z-index: 5;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #fbbf24;
  box-shadow:
    0 0 12rpx rgba(251, 191, 36, 0.95),
    0 0 24rpx rgba(252, 211, 77, 0.45);
  transform: translate(-50%, -50%);
  animation: qimen-scan-dot 5.2s ease-in-out infinite;
  pointer-events: none;
}

.qimen-scan-grid--compact .qimen-scan-grid__dot {
  width: 10rpx;
  height: 10rpx;
}

.qimen-scan-grid--compact .qimen-scan-grid__scan-line,
.qimen-scan-grid--compact .qimen-scan-grid__scan-diagonal {
  opacity: 0.72;
}

@keyframes qimen-scan-line-v {
  0%,
  100% {
    top: 10%;
    opacity: 0;
  }

  8% {
    opacity: 0.85;
  }

  42% {
    top: 88%;
    opacity: 0.85;
  }

  52%,
  100% {
    top: 88%;
    opacity: 0;
  }
}

@keyframes qimen-scan-diagonal {
  0%,
  100% {
    top: -35%;
    left: -40%;
    opacity: 0;
  }

  10% {
    opacity: 0.55;
  }

  45% {
    top: 75%;
    left: 35%;
    opacity: 0.55;
  }

  55%,
  100% {
    top: 75%;
    left: 35%;
    opacity: 0;
  }
}

@keyframes qimen-scan-dot {
  0%,
  100% {
    top: 17%;
    left: 17%;
  }

  9% {
    top: 17%;
    left: 50%;
  }

  18% {
    top: 17%;
    left: 83%;
  }

  27% {
    top: 50%;
    left: 83%;
  }

  36% {
    top: 83%;
    left: 83%;
  }

  45% {
    top: 83%;
    left: 50%;
  }

  54% {
    top: 83%;
    left: 17%;
  }

  63% {
    top: 50%;
    left: 17%;
  }

  72% {
    top: 50%;
    left: 50%;
  }

  81% {
    top: 17%;
    left: 50%;
  }

  90% {
    top: 50%;
    left: 50%;
  }
}

@keyframes qimen-cell-glow {
  0%,
  10%,
  100% {
    background: rgba(255, 255, 255, 0.42);
    border-color: rgba(146, 64, 14, 0.28);
    box-shadow: none;
  }

  5% {
    background: rgba(255, 251, 235, 0.92);
    border-color: rgba(217, 119, 6, 0.52);
    box-shadow: 0 0 14rpx rgba(252, 211, 77, 0.32);
  }
}
