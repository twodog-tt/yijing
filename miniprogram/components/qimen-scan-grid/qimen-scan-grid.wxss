.qimen-scan-grid {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  margin: 8rpx 0 16rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: rgba(250, 250, 249, 0.6);
}

.qimen-scan-grid--compact {
  width: 120rpx;
  height: 120rpx;
  margin: 0;
  border-radius: 12rpx;
}

.qimen-scan-grid__cells {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6rpx;
  width: 100%;
  height: 100%;
  padding: 10rpx;
  box-sizing: border-box;
}

.qimen-scan-grid__cell {
  border: 1rpx solid rgba(120, 113, 108, 0.45);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.35);
}

.qimen-scan-grid__scan-h {
  position: absolute;
  top: 0;
  left: -100%;
  z-index: 2;
  width: 60%;
  height: 100%;
  background: linear-gradient(
    90deg,
    rgba(146, 64, 14, 0) 0%,
    rgba(252, 211, 77, 0.22) 50%,
    rgba(146, 64, 14, 0) 100%
  );
  animation: qimen-scan-sweep-h 3.2s ease-in-out infinite;
  pointer-events: none;
}

.qimen-scan-grid__scan-v {
  position: absolute;
  top: -100%;
  left: 0;
  z-index: 2;
  width: 100%;
  height: 40%;
  background: linear-gradient(
    180deg,
    rgba(146, 64, 14, 0) 0%,
    rgba(252, 211, 77, 0.16) 50%,
    rgba(146, 64, 14, 0) 100%
  );
  animation: qimen-scan-sweep-v 4.8s ease-in-out infinite;
  pointer-events: none;
}

.qimen-scan-grid__dot {
  position: absolute;
  z-index: 3;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #fbbf24;
  box-shadow: 0 0 16rpx rgba(251, 191, 36, 0.85);
  animation: qimen-scan-dot 5.6s linear infinite;
  pointer-events: none;
}

.qimen-scan-grid--compact .qimen-scan-grid__dot {
  width: 10rpx;
  height: 10rpx;
}

@keyframes qimen-scan-sweep-h {
  0% {
    left: -60%;
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  50% {
    left: 100%;
    opacity: 1;
  }
  60%,
  100% {
    left: 100%;
    opacity: 0;
  }
}

@keyframes qimen-scan-sweep-v {
  0%,
  40% {
    top: -40%;
    opacity: 0;
  }
  50% {
    opacity: 1;
  }
  90% {
    top: 100%;
    opacity: 1;
  }
  100% {
    top: 100%;
    opacity: 0;
  }
}

@keyframes qimen-scan-dot {
  0% {
    top: 18%;
    left: 18%;
  }
  11% {
    top: 18%;
    left: 50%;
  }
  22% {
    top: 18%;
    left: 82%;
  }
  33% {
    top: 50%;
    left: 82%;
  }
  44% {
    top: 82%;
    left: 82%;
  }
  55% {
    top: 82%;
    left: 50%;
  }
  66% {
    top: 82%;
    left: 18%;
  }
  77% {
    top: 50%;
    left: 18%;
  }
  88% {
    top: 50%;
    left: 50%;
  }
  100% {
    top: 18%;
    left: 18%;
  }
}
