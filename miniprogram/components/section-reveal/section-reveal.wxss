.section-reveal {
  opacity: 0;
  transform: translateY(36rpx);
}

.section-reveal--active {
  animation: section-reveal-rise 0.62s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.section-reveal--static {
  opacity: 1;
  transform: none;
  animation: none;
}

@keyframes section-reveal-rise {
  from {
    opacity: 0;
    transform: translateY(36rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.pillar-card--flip {
  opacity: 0;
  transform: perspective(800rpx) rotateY(-22deg) translateY(28rpx);
}

.section-reveal--active .pillar-card--flip {
  animation: pillar-card-flip 0.58s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

@keyframes pillar-card-flip {
  from {
    opacity: 0;
    transform: perspective(800rpx) rotateY(-22deg) translateY(28rpx);
  }

  to {
    opacity: 1;
    transform: perspective(800rpx) rotateY(0deg) translateY(0);
  }
}
