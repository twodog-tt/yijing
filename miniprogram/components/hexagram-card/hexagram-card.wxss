.card {
  padding: 32rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.card--changed {
  border-color: #fde68a;
  background: #fffbeb;
}

.label,
.name,
.full-name,
.number,
.summary,
.empty {
  display: block;
}

.label {
  color: #92400e;
  font-size: 24rpx;
  font-weight: 600;
}

.name {
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.full-name {
  margin-top: 8rpx;
  color: #57534e;
  font-size: 26rpx;
  word-break: break-all;
}

.number {
  margin-top: 12rpx;
  color: #a8a29e;
  font-size: 22rpx;
}

.summary,
.empty {
  margin-top: 18rpx;
  color: #78716c;
  font-size: 24rpx;
  line-height: 1.65;
  word-break: break-all;
}
