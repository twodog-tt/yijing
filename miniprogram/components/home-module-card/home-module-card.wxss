.home-module-card {
  position: relative;
  display: block;
  overflow: hidden;
  margin-bottom: 16rpx;
  padding: 24rpx 24rpx 22rpx 34rpx;
  border: 1rpx solid rgba(214, 176, 109, 0.24);
  border-radius: 20rpx;
  background: #fffaf0;
  box-shadow: 0 14rpx 32rpx rgba(0, 0, 0, 0.16);
  box-sizing: border-box;
}

.home-module-card__accent {
  position: absolute;
  top: 24rpx;
  bottom: 24rpx;
  left: 0;
  width: 7rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: #b99255;
}

.home-module-card--ask {
  border-color: rgba(185, 146, 85, 0.42);
}

.home-module-card--bazi {
  border-color: rgba(18, 123, 111, 0.22);
}

.home-module-card--bazi .home-module-card__accent {
  background: #127b6f;
}

.home-module-card--qimen {
  border-color: rgba(123, 57, 37, 0.24);
}

.home-module-card--qimen .home-module-card__accent {
  background: #7b3925;
}

.home-module-card__header {
  margin-bottom: 14rpx;
}

.home-module-card__title {
  display: block;
  color: #241c15;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.4;
}

.home-module-card__subtitle {
  display: block;
  margin-top: 8rpx;
  color: #5f5549;
  font-size: 24rpx;
  line-height: 1.55;
}

.home-module-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.home-module-card__tag {
  padding: 6rpx 14rpx;
  border: 1rpx solid #eadfcb;
  border-radius: 999rpx;
  background: #f7efe1;
  color: #625846;
  font-size: 20rpx;
  line-height: 1.4;
}

.home-module-card__action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 56rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #efe3cf;
}

.home-module-card__button {
  color: #241c15;
  font-size: 25rpx;
  font-weight: 600;
}

.home-module-card__arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #241c15;
  color: #f4ead8;
  font-size: 25rpx;
}
