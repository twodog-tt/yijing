.home-module-card {
  display: block;
  margin-bottom: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(252, 211, 77, 0.22);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #1c1917 0%, #292524 100%);
  box-shadow: 0 12rpx 28rpx rgba(28, 25, 23, 0.16);
  box-sizing: border-box;
}

.home-module-card--ask {
  border-color: rgba(252, 211, 77, 0.34);
}

.home-module-card--bazi {
  border-color: rgba(217, 119, 6, 0.28);
}

.home-module-card--qimen {
  border-color: rgba(161, 98, 7, 0.28);
}

.home-module-card__header {
  margin-bottom: 20rpx;
}

.home-module-card__title {
  display: block;
  color: #fef3c7;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.home-module-card__subtitle {
  display: block;
  margin-top: 10rpx;
  color: #d6d3d1;
  font-size: 24rpx;
  line-height: 1.65;
}

.home-module-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.home-module-card__tag {
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(252, 211, 77, 0.24);
  border-radius: 999rpx;
  background: rgba(252, 211, 77, 0.08);
  color: #fcd34d;
  font-size: 22rpx;
  line-height: 1.4;
}

.home-module-card__action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.home-module-card__button {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.home-module-card__arrow {
  color: #fcd34d;
  font-size: 30rpx;
}
