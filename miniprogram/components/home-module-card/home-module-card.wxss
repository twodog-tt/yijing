.home-module-card {
  position: relative;
  display: block;
  overflow: hidden;
  margin-bottom: 18rpx;
  padding: 30rpx 28rpx 26rpx 36rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(41, 37, 36, 0.07);
  box-sizing: border-box;
}

.home-module-card__accent {
  position: absolute;
  top: 28rpx;
  bottom: 28rpx;
  left: 0;
  width: 8rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: #b45309;
}

.home-module-card--ask {
  border-color: rgba(180, 83, 9, 0.28);
}

.home-module-card--bazi {
  border-color: rgba(15, 118, 110, 0.22);
}

.home-module-card--bazi .home-module-card__accent {
  background: #0f766e;
}

.home-module-card--qimen {
  border-color: rgba(124, 45, 18, 0.22);
}

.home-module-card--qimen .home-module-card__accent {
  background: #7c2d12;
}

.home-module-card__header {
  margin-bottom: 18rpx;
}

.home-module-card__title {
  display: block;
  color: #292524;
  font-size: 33rpx;
  font-weight: 700;
  line-height: 1.4;
}

.home-module-card__subtitle {
  display: block;
  margin-top: 10rpx;
  color: #57534e;
  font-size: 25rpx;
  line-height: 1.65;
}

.home-module-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.home-module-card__tag {
  padding: 8rpx 16rpx;
  border: 1rpx solid #e7e5e4;
  border-radius: 999rpx;
  background: #fafaf9;
  color: #57534e;
  font-size: 22rpx;
  line-height: 1.4;
}

.home-module-card__action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 64rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #f5f5f4;
}

.home-module-card__button {
  color: #292524;
  font-size: 27rpx;
  font-weight: 600;
}

.home-module-card__arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #292524;
  color: #fef3c7;
  font-size: 28rpx;
}
