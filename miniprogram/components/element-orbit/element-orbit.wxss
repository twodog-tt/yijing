.element-orbit {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  margin: 16rpx auto 8rpx;
}

.element-orbit__ring {
  position: absolute;
  top: 50%;
  left: 50%;
  border-radius: 50%;
  border: 2rpx solid rgba(146, 64, 14, 0.18);
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.element-orbit__ring--outer {
  width: 280rpx;
  height: 280rpx;
  animation: element-orbit-ring 6s ease-in-out infinite;
}

.element-orbit__ring--inner {
  width: 200rpx;
  height: 200rpx;
  border-color: rgba(252, 211, 77, 0.35);
  animation: element-orbit-ring 6s ease-in-out infinite reverse;
}

.element-orbit__center {
  position: absolute;
  top: 50%;
  left: 50%;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 251, 235, 0.92);
  box-shadow: 0 0 24rpx rgba(252, 211, 77, 0.25);
  transform: translate(-50%, -50%);
}

.element-orbit__title {
  color: #92400e;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.element-orbit__subtitle {
  margin-top: 6rpx;
  color: #78716c;
  font-size: 20rpx;
}

.element-orbit__track {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  animation: element-orbit-spin 14s linear infinite;
}

.element-orbit__node {
  position: absolute;
  top: 50%;
  left: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  margin: -28rpx 0 0 -28rpx;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(41, 37, 36, 0.08);
  transform: rotate(calc(var(--i) * 72deg)) translateY(-122rpx)
    rotate(calc(var(--i) * -72deg));
  animation: element-orbit-node-pulse 14s ease-in-out infinite;
  animation-delay: calc(var(--i) * -2.8s);
}

.element-orbit__node--wood {
  color: #166534;
  background: rgba(22, 101, 52, 0.12);
}

.element-orbit__node--fire {
  color: #c2410c;
  background: rgba(194, 65, 12, 0.12);
}

.element-orbit__node--earth {
  color: #92400e;
  background: rgba(146, 64, 14, 0.12);
}

.element-orbit__node--metal {
  color: #57534e;
  background: rgba(87, 83, 78, 0.12);
}

.element-orbit__node--water {
  color: #1d4ed8;
  background: rgba(29, 78, 216, 0.12);
}

@keyframes element-orbit-spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes element-orbit-ring {
  0%,
  100% {
    opacity: 0.55;
    transform: translate(-50%, -50%) scale(1);
  }
  50% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.04);
  }
}

@keyframes element-orbit-node-pulse {
  0%,
  10%,
  100% {
    opacity: 0.55;
    transform: rotate(calc(var(--i) * 72deg)) translateY(-122rpx)
      rotate(calc(var(--i) * -72deg)) scale(1);
  }
  5% {
    opacity: 1;
    transform: rotate(calc(var(--i) * 72deg)) translateY(-122rpx)
      rotate(calc(var(--i) * -72deg)) scale(1.12);
    box-shadow: 0 0 20rpx rgba(252, 211, 77, 0.45);
  }
}
