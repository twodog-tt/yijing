# 阿里云 ECS 内测环境变量示例
# 复制为 .env.internal-test 后替换 SERVER_IP 与所有 CHANGE_ME 占位符。
# .env 与 .env.production 可安全链接到它；切勿提交任何含真实密钥的环境文件。

# ---------- 服务器占位（全文搜索替换 SERVER_IP）----------
# 示例：123.45.67.89
SERVER_IP=SERVER_IP

# ---------- MySQL（Docker 内部）----------
MYSQL_ROOT_PASSWORD=CHANGE_ME_root
MYSQL_DATABASE=yijing
MYSQL_USER=yijing
MYSQL_PASSWORD=CHANGE_ME_db
# 不映射宿主机 3306；备份脚本通过 docker exec 访问

# ---------- Go Backend ----------
APP_ENV=production
BACKEND_PORT=8080

# 默认留空，由 docker-compose.prod.yml 根据上面的 MYSQL_* 生成 DB_* 配置。
# 若未来切换外部数据库，再在服务器上填写完整 DSN。
DATABASE_DSN=
DB_HOST=mysql
DB_PORT=3306

# ---------- AI（完整解读）----------
# 内测可先用 mock；邀请朋友体验 DeepSeek 时改为 deepseek 并填写 Key
AI_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_OUTPUT_TOKENS=1800

# ---------- 安全 ----------
ENABLE_DEBUG_ROUTES=false
CORS_ALLOWED_ORIGINS=http://SERVER_IP
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=20

# ---------- 前端 build 参数（修改后需重新 build frontend 镜像）----------
NEXT_PUBLIC_API_BASE_URL=http://SERVER_IP/api/v1
NEXT_PUBLIC_SITE_URL=http://SERVER_IP

# ---------- 可选：仅绑定本机端口（一般无需改）----------
FRONTEND_PORT=3000
