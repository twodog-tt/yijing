# 阿里云 ECS 内测环境变量示例
# 复制为 .env 后替换 SERVER_IP 与所有 CHANGE_ME 占位符，切勿提交含真实密钥的 .env

# ---------- 服务器占位（全文搜索替换 SERVER_IP）----------
# 示例：123.45.67.89
SERVER_IP=SERVER_IP

# ---------- MySQL（Docker 内部）----------
MYSQL_ROOT_PASSWORD=CHANGE_ME_root
MYSQL_DATABASE=yijing
MYSQL_USER=yijing
MYSQL_PASSWORD=CHANGE_ME_db
# 不映射宿主机 3306；备份脚本通过 docker exec 访问

# ---------- Go Backend ----------
APP_ENV=production
BACKEND_PORT=8080

# 方式 A：完整 DSN（推荐，主机名用 Docker 服务名 mysql）
DATABASE_DSN=yijing:CHANGE_ME_db@tcp(mysql:3306)/yijing?parseTime=true&charset=utf8mb4&loc=Local

# 方式 B：分项配置（若 DATABASE_DSN 为空则使用下列项）
DB_HOST=mysql
DB_PORT=3306
DB_USER=yijing
DB_PASSWORD=CHANGE_ME_db
DB_NAME=yijing

# ---------- AI（完整解读）----------
# 内测可先用 mock；邀请朋友体验 DeepSeek 时改为 deepseek 并填写 Key
AI_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_OUTPUT_TOKENS=1800

# ---------- 安全 ----------
ENABLE_DEBUG_ROUTES=false
CORS_ALLOWED_ORIGINS=http://SERVER_IP
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=20

# ---------- 前端 build 参数（修改后需重新 build frontend 镜像）----------
NEXT_PUBLIC_API_BASE_URL=http://SERVER_IP/api/v1
NEXT_PUBLIC_SITE_URL=http://SERVER_IP

# ---------- 可选：仅绑定本机端口（一般无需改）----------
FRONTEND_PORT=3000
