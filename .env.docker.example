# Docker Compose 全栈一键启动环境变量示例
# 复制为项目根目录 .env 后执行: docker compose up --build

# MySQL
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=yijing
MYSQL_USER=yijing
MYSQL_PASSWORD=yijingpass
MYSQL_PORT=3306

# Go Backend（容器内通过服务名 mysql 连接数据库）
APP_ENV=development
BACKEND_PORT=8080
DB_PORT=3306
DB_USER=yijing
DB_PASSWORD=yijingpass
DB_NAME=yijing

# Next.js Frontend（构建时注入，浏览器从宿主机访问 localhost，不要用 backend 服务名）
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Provider（仅后端使用，切勿提交真实 API Key）
AI_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_OUTPUT_TOKENS=1800

# Security & ops（Docker 本地验收可开启 debug）
ENABLE_DEBUG_ROUTES=true
CORS_ALLOWED_ORIGINS=http://localhost:3000
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=20
